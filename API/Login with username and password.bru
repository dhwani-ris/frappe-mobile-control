meta {
  name: Login with username and password
  type: http
  seq: 1
}

post {
  url: {{base_url}}method/mobile_auth.login
  body: json
  auth: inherit
}

body:json {
  {
    "username" : "{{username}}",
    "password" : "{{password}}"
  }
}

vars:pre-request {
  base_url: your base url
}

settings {
  encodeUrl: true
  timeout: 0
}
