meta {
  name: get_translations
  type: http
  seq: 9
}

# Optional query: ?lang=hi (or lang=hi,en for multiple); &all=1 for full translations (default: DB only)
get {
  url: {{base_url}}method/mobile_auth.get_translations
  body: none
  auth: bearer
}

auth:bearer {
  token: your token
}

vars:pre-request {
  base_url: your base url
}

settings {
  encodeUrl: true
  timeout: 0
}
